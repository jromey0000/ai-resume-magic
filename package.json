{
  "name": "ai-resume-magic",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "src/frontend",
    "src/backend"
  ],
  "scripts": {
    "dev": "concurrently -n frontend,backend -c blue,green \"bun run dev:frontend\" \"bun run dev:backend\"",
    "dev:frontend": "bun run --cwd src/frontend dev",
    "dev:backend": "bun run --cwd src/backend develop",
    "build": "bun run build:frontend && bun run build:backend",
    "build:frontend": "bun run --cwd src/frontend build",
    "build:backend": "bun run --cwd src/backend build",
    "start": "concurrently -n frontend,backend -c blue,green \"bun run start:frontend\" \"bun run start:backend\"",
    "start:frontend": "bun run --cwd src/frontend preview",
    "start:backend": "bun run --cwd src/backend start",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "test": "bun run --cwd src/frontend test",
    "test:watch": "bun run --cwd src/frontend test:watch",
    "install:all": "bun install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "concurrently": "^10.0.3",
    "typescript": "~6.0.3"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.10",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^6.0.227",
    "radix-ui": "^1.6.0"
  }
}
